{
  "name": "react-iframe-communication",
  "version": "0.1.0",
  "description": "React hooks for iframe communication with request-response pattern. Easy type-safe communication between parent window and iframes.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "author": "xiaosikai <xiaosaikai@qq.com>",
  "homepage": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "dev:parent": "vite --port 3000",
    "dev:iframe": "vite --port 3001",
    "build": "tsup",
    "build:lib": "tsup",
    "build:site": "vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "preview": "vite preview"
  },
  "keywords": [
    "react",
    "iframe",
    "postmessage",
    "communication",
    "hooks",
    "request-response",
    "typescript",
    "type-safe",
    "parent-child",
    "window-communication"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.5.0",
    "eslint": "^9.0.0",
    "jsdom": "^24.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
}
